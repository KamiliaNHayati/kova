# Kova Agent Environment Config
# Copy this file to .env and fill in your values

# ─── Wallet Config ────────────────────────────────────
# Your 24-word seed phrase from Hiro Wallet
# Settings → View Secret Key → copy all 24 words
AGENT_MNEMONIC=word1 word2 word3 ... word24

# Account index for the agent (0 = first account)
AGENT_ACCOUNT_INDEX=0

# Account index for the operator (signs agent-pay, pays gas)
# Must match the address you registered via register-operator on-chain
OPERATOR_ACCOUNT_INDEX=1

# ─── Contract Config ──────────────────────────────────
# Your Hiro wallet address (owner of the escrow)
OWNER_ADDRESS=ST...your-owner-address

# Address that deployed agent-wallet-v7.clar
CONTRACT_ADDRESS=ST...deployer-address

# X402 service server URL
SERVICE_URL=http://localhost:3402

# ─── Telegram Bot (optional) ──────────────────────────
# Human-in-the-loop payment approval via Telegram
# 1. Open Telegram → search @BotFather → /newbot
# 2. Copy the token and paste below
# 3. Send /start to your bot — chat ID is auto-detected
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APPROVAL_THRESHOLD_STX=1

# ─── Agent Scheduler ──────────────────────────────────
# SCHEDULE_MODE options:
#   idle     — wait for API calls (default for demo)
#   once     — run services once then exit
#   interval — run every SCHEDULE_INTERVAL minutes
SCHEDULE_MODE=idle
SCHEDULE_INTERVAL=5

# Comma-separated service endpoints to call each run
SERVICE_ENDPOINTS=/api/price-feed

# ─── Data Delivery ────────────────────────────────────
# DELIVERY_MODE options:
#   off     — log to terminal only (default)
#   webhook — POST results to WEBHOOK_URL
#   api     — serve at localhost:AGENT_API_PORT/api/latest
#   both    — webhook + api
DELIVERY_MODE=off
WEBHOOK_URL=
AGENT_API_PORT=4000

# ─── LLM Config ───────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...your-key-here

# ─── Internal ─────────────────────────────────────────
# Shared secret between agent and frontend for heartbeat indicators
# Change this to any random string for security
HEARTBEAT_SECRET=kova-demo-secret