# Kova Agent Environment Config
# Copy this to .env and fill in your values

# ─── Wallet Key (pick ONE option) ────────────────────

# Option A: Mnemonic (recommended — from Hiro Wallet)
# Go to Hiro Wallet → Settings → View Secret Key → copy 24 words
AGENT_MNEMONIC=word1 word2 word3 ... word24
AGENT_ACCOUNT_INDEX=2

# Option B: Raw private key (hex)
# AGENT_PRIVATE_KEY=abc123...hex

# ─── Contract Config ─────────────────────────────────
OWNER_ADDRESS=STWEW038MP9DGVVMBZMVBJ6KZXC39Y5NHWY5CC37
CONTRACT_ADDRESS=STWEW038MP9DGVVMBZMVBJ6KZXC39Y5NHWY5CC37
SERVICE_URL=http://localhost:3402

# ─── Operator Config (signs agent-pay, pays gas) ─────
# The operator is derived from the SAME mnemonic, different account index.
# Owner must call register-operator(operator_address) on-chain once.
# Option A: Use mnemonic + index (recommended)
OPERATOR_ACCOUNT_INDEX=0
# Option B: Raw private key (overrides mnemonic derivation)
# OPERATOR_PRIVATE_KEY=abc123...hex
# If neither is set, falls back to AGENT_KEY (agent = operator).

# ─── Telegram Bot (optional, for human-in-the-loop) ──
# 1. Create a bot: Telegram → @BotFather → /newbot
# 2. Paste the token below
# 3. Start the agent, then send /start to your bot
# 4. The bot will auto-detect your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APPROVAL_THRESHOLD_STX=10

# ─── Agent Scheduler ─────────────────────────────────
# SCHEDULE_MODE: once (default) | interval
#   once     — run services once, then exit
#   interval — run all services every SCHEDULE_INTERVAL minutes
SCHEDULE_MODE=once
SCHEDULE_INTERVAL=5

# Comma-separated list of service endpoints to call
SERVICE_ENDPOINTS=/api/price-feed

# ─── Data Delivery (optional) ────────────────────────
# DELIVERY_MODE: off (default) | webhook | api | both
#   off     — just log to terminal
#   webhook — POST results to WEBHOOK_URL after each run
#   api     — serve latest results at http://localhost:AGENT_API_PORT/api/latest
#   both    — webhook + api combined
DELIVERY_MODE=api
WEBHOOK_URL=
AGENT_API_PORT=4000
